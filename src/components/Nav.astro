---
interface Props {
  lightText?: boolean;
}
const { lightText = false } = Astro.props;

const navLinks = [
  { label: 'Início', href: '/' },
  { label: 'Sobre', href: '/#sobre' },
  { label: 'Serviços', href: '/#servicos' },
  // { label: 'Portfólio', href: '/#portfolio' },
  { label: 'Blog', href: '/blog' },
  { label: 'Contato', href: '/#contato' },
];
---

<header id="nav" class="fixed top-0 left-0 right-0 z-50 transition-all duration-500" style="background: transparent;" data-light-text={lightText ? "true" : "false"}>
  <div class="max-w-7xl mx-auto px-6 lg:px-12 flex items-center justify-between h-20">
    <a href="/" id="nav-logo" class="font-display text-2xl font-light tracking-[0.15em] hover:text-[var(--color-rose)] transition-colors duration-300" style={lightText ? "color: #FAF8F4;" : "color: var(--color-charcoal);"}>
      VANY
    </a>

    <!-- Desktop -->
    <nav class="hidden md:flex items-center gap-8">
      {navLinks.map((link) => (
        <a
          href={link.href}
          class="nav-link text-xs tracking-[0.2em] uppercase font-body font-medium hover:text-[var(--color-rose)] transition-colors duration-300 relative group"
          style={lightText ? "color: rgba(250,248,244,0.85);" : "color: var(--color-charcoal-soft);"}
        >
          {link.label}
          <span class="absolute -bottom-0.5 left-0 w-0 h-px bg-[var(--color-rose)] transition-all duration-300 group-hover:w-full"></span>
        </a>
      ))}

      <!-- YouTube icon -->
      <a
        href="https://youtube.com/@vanymodelista"
        target="_blank"
        rel="noopener noreferrer"
        aria-label="YouTube"
        id="nav-yt"
        class="nav-link hover:text-red-600 transition-colors duration-300"
        style={lightText ? "color: rgba(250,248,244,0.85);" : "color: var(--color-charcoal-soft);"}
      >
        <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24">
          <path d="M23.498 6.186a3.016 3.016 0 0 0-2.122-2.136C19.505 3.545 12 3.545 12 3.545s-7.505 0-9.377.505A3.017 3.017 0 0 0 .502 6.186C0 8.07 0 12 0 12s0 3.93.502 5.814a3.016 3.016 0 0 0 2.122 2.136c1.871.505 9.376.505 9.376.505s7.505 0 9.377-.505a3.015 3.015 0 0 0 2.122-2.136C24 15.93 24 12 24 12s0-3.93-.502-5.814zM9.545 15.568V8.432L15.818 12l-6.273 3.568z"/>
        </svg>
      </a>
    </nav>

    <!-- Mobile toggle -->
    <button id="menu-btn" class="md:hidden flex flex-col gap-1.5 p-2" aria-label="Menu">
      <span class="menu-bar w-6 h-px transition-all duration-300 block" style={lightText ? "background-color: #FAF8F4;" : "background-color: var(--color-charcoal);"}></span>
      <span class="menu-bar w-4 h-px transition-all duration-300 block" style={lightText ? "background-color: #FAF8F4;" : "background-color: var(--color-charcoal);"}></span>
      <span class="menu-bar w-6 h-px transition-all duration-300 block" style={lightText ? "background-color: #FAF8F4;" : "background-color: var(--color-charcoal);"}></span>
    </button>
  </div>

  <!-- Mobile menu -->
  <div id="mobile-menu" class="md:hidden hidden bg-[var(--color-cream)] border-t border-[var(--color-cream-dark)]">
    <nav class="flex flex-col px-6 py-8 gap-6">
      {navLinks.map((link) => (
        <a
          href={link.href}
          class="text-sm tracking-[0.2em] uppercase font-medium text-[var(--color-charcoal-soft)] hover:text-[var(--color-rose)] transition-colors duration-300"
        >
          {link.label}
        </a>
      ))}
      <a
        href="https://youtube.com/@vanymodelista"
        target="_blank"
        rel="noopener noreferrer"
        class="flex items-center gap-2 text-sm tracking-[0.2em] uppercase font-medium text-[var(--color-charcoal-soft)] hover:text-red-600 transition-colors duration-300"
      >
        <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24">
          <path d="M23.498 6.186a3.016 3.016 0 0 0-2.122-2.136C19.505 3.545 12 3.545 12 3.545s-7.505 0-9.377.505A3.017 3.017 0 0 0 .502 6.186C0 8.07 0 12 0 12s0 3.93.502 5.814a3.016 3.016 0 0 0 2.122 2.136c1.871.505 9.376.505 9.376.505s7.505 0 9.377-.505a3.015 3.015 0 0 0 2.122-2.136C24 15.93 24 12 24 12s0-3.93-.502-5.814zM9.545 15.568V8.432L15.818 12l-6.273 3.568z"/>
        </svg>
        YouTube
      </a>
    </nav>
  </div>
</header>

<script>
  const nav = document.getElementById('nav')!;
  const menuBtn = document.getElementById('menu-btn')!;
  const mobileMenu = document.getElementById('mobile-menu')!;
  const isLight = nav.dataset.lightText === 'true';

  const logo = document.getElementById('nav-logo') as HTMLAnchorElement;
  const links = document.querySelectorAll<HTMLElement>('.nav-link');
  const bars = document.querySelectorAll<HTMLElement>('.menu-bar');

  function setDarkText() {
    if (logo) logo.style.color = 'var(--color-charcoal)';
    links.forEach(l => l.style.color = 'var(--color-charcoal-soft)');
    bars.forEach(b => b.style.backgroundColor = 'var(--color-charcoal)');
  }

  function setLightText() {
    if (logo) logo.style.color = '#FAF8F4';
    links.forEach(l => l.style.color = 'rgba(250,248,244,0.85)');
    bars.forEach(b => b.style.backgroundColor = '#FAF8F4');
  }

  window.addEventListener('scroll', () => {
    if (window.scrollY > 60) {
      nav.style.background = 'rgba(250, 248, 244, 0.95)';
      nav.style.backdropFilter = 'blur(12px)';
      nav.style.boxShadow = '0 1px 0 rgba(28,25,23,0.06)';
      setDarkText();
    } else {
      nav.style.background = 'transparent';
      nav.style.backdropFilter = 'none';
      nav.style.boxShadow = 'none';
      if (isLight) setLightText();
    }
  });

  menuBtn.addEventListener('click', () => {
    mobileMenu.classList.toggle('hidden');
  });

  mobileMenu.querySelectorAll('a').forEach(link => {
    link.addEventListener('click', () => mobileMenu.classList.add('hidden'));
  });
</script>
