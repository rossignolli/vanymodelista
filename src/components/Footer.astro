---
---

<footer style="background-color: #1C1917; color: #FAF8F4;" class="py-16 px-6 lg:px-12">
  <div class="max-w-7xl mx-auto">
    <div class="grid grid-cols-1 md:grid-cols-4 gap-12 mb-14">
      <div>
        <p class="font-display text-3xl font-light tracking-[0.15em] mb-4">VANY</p>
        <p class="text-xs tracking-[0.15em] uppercase mb-4" style="color: #8C7B74;">Modelista de Moda</p>
        <p class="text-sm font-light leading-relaxed max-w-xs" style="color: #8C7B74;">
          Transformando visões em peças que existem apenas uma vez.
        </p>

        <!-- Redes sociais -->
        <div class="flex items-center gap-4 mt-6">
          <a href="https://instagram.com/vanymodelista" target="_blank" rel="noopener noreferrer" aria-label="Instagram"
            class="transition-colors duration-300 hover:text-rose-light" style="color: #8C7B74;">
            <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24">
              <path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zm0-2.163c-3.259 0-3.667.014-4.947.072-4.358.2-6.78 2.618-6.98 6.98-.059 1.281-.073 1.689-.073 4.948 0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98 1.281.058 1.689.072 4.948.072 3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98-1.281-.059-1.69-.073-4.949-.073zm0 5.838c-3.403 0-6.162 2.759-6.162 6.162s2.759 6.163 6.162 6.163 6.162-2.759 6.162-6.163c0-3.403-2.759-6.162-6.162-6.162zm0 10.162c-2.209 0-4-1.79-4-4 0-2.209 1.791-4 4-4s4 1.791 4 4c0 2.21-1.791 4-4 4zm6.406-11.845c-.796 0-1.441.645-1.441 1.44s.645 1.44 1.441 1.44c.795 0 1.439-.645 1.439-1.44s-.644-1.44-1.439-1.44z"/>
            </svg>
          </a>
          <a href="https://youtube.com/@vanymodelista" target="_blank" rel="noopener noreferrer" aria-label="YouTube"
            class="transition-colors duration-300 hover:text-red-500" style="color: #8C7B74;">
            <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24">
              <path d="M23.498 6.186a3.016 3.016 0 0 0-2.122-2.136C19.505 3.545 12 3.545 12 3.545s-7.505 0-9.377.505A3.017 3.017 0 0 0 .502 6.186C0 8.07 0 12 0 12s0 3.93.502 5.814a3.016 3.016 0 0 0 2.122 2.136c1.871.505 9.376.505 9.376.505s7.505 0 9.377-.505a3.015 3.015 0 0 0 2.122-2.136C24 15.93 24 12 24 12s0-3.93-.502-5.814zM9.545 15.568V8.432L15.818 12l-6.273 3.568z"/>
            </svg>
          </a>
        </div>
      </div>

      <div>
        <p class="text-xs tracking-[0.2em] uppercase mb-5 font-medium" style="color: #D4A88A;">Navegação</p>
        <nav class="flex flex-col gap-3">
          {[
            { label: 'Início', href: '/' },
            { label: 'Sobre', href: '/#sobre' },
            { label: 'Serviços', href: '/#servicos' },
            { label: 'Portfólio', href: '/#portfolio' },
            { label: 'Blog', href: '/blog' },
            { label: 'Contato', href: '/#contato' },
          ].map(link => (
            <a href={link.href} class="text-sm font-light tracking-wide transition-colors duration-300 hover:text-rose-light" style="color: #8C7B74;">
              {link.label}
            </a>
          ))}
        </nav>
      </div>

      <div>
        <p class="text-xs tracking-[0.2em] uppercase mb-5 font-medium" style="color: #D4A88A;">Contato</p>
        <div class="flex flex-col gap-3">
          <a href="mailto:vany@modelista.com" class="text-sm font-light transition-colors duration-300 hover:text-rose-light" style="color: #8C7B74;">
            vany@modelista.com
          </a>
          <a href="https://instagram.com/vanymodelista" target="_blank" rel="noopener noreferrer" class="text-sm font-light transition-colors duration-300 hover:text-rose-light" style="color: #8C7B74;">
            @vanymodelista
          </a>
          <a href="https://youtube.com/@vanymodelista" target="_blank" rel="noopener noreferrer" class="text-sm font-light transition-colors duration-300 hover:text-red-500" style="color: #8C7B74;">
            YouTube
          </a>
          <p class="text-sm font-light" style="color: #8C7B74;">Lins, SP — Brasil</p>
        </div>
      </div>

      <div>
        <p class="text-xs tracking-[0.2em] uppercase mb-5 font-medium" style="color: #D4A88A;">Localização</p>
        <div class="overflow-hidden" style="border: 1px solid rgba(255,255,255,0.08);">
          <iframe
            src="https://www.google.com/maps/embed?pb=!1m18!1m12!1m3!1d59434.46820571988!2d-49.77583!3d-21.6825!2m3!1f0!2f0!3f0!3m2!1i1024!2i768!4f13.1!3m3!1m2!1s0x94bf58b7f8e4e135%3A0x2c7f3e7f6c8b1a2!2sLins%2C%20SP!5e0!3m2!1spt-BR!2sbr!4v1700000000000"
            width="100%"
            height="160"
            style="border:0; filter: grayscale(100%) invert(10%) sepia(10%);"
            allowfullscreen=""
            loading="lazy"
            referrerpolicy="no-referrer-when-downgrade"
            title="Localização — Lins, SP"
          ></iframe>
        </div>
      </div>
    </div>

    <div class="pt-8 flex flex-col md:flex-row justify-between items-center gap-4" style="border-top: 1px solid rgba(255,255,255,0.08);">
      <p class="text-xs tracking-wide" style="color: #8C7B74;">
        © 2024 Vany Modelista. Todos os direitos reservados.
      </p>
      <p class="text-xs tracking-wide" style="color: rgba(140,123,116,0.5);">
        Alta Costura · Modelagem · Alfaiataria
      </p>
    </div>
  </div>
</footer>
