---
import Layout from '../layouts/Layout.astro';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';
import { getCollection } from 'astro:content';

const UNSPLASH = 'https://images.unsplash.com';

// Busca último vídeo do canal via RSS (sem API key, no build time)
let latestVideo = { id: '', title: 'Último vídeo', thumbnail: '' };
try {
  const rss = await fetch('https://www.youtube.com/feeds/videos.xml?channel_id=UC9_KWopiNSiCzOtHrSbYJ2Q');
  const xml = await rss.text();
  const idMatch = xml.match(/<yt:videoId>([^<]+)<\/yt:videoId>/);
  const titleMatch = xml.match(/<title>([^<]+)<\/title>/g);
  if (idMatch) {
    latestVideo.id = idMatch[1];
    latestVideo.thumbnail = `https://i.ytimg.com/vi/${idMatch[1]}/maxresdefault.jpg`;
    // segundo <title> é o do vídeo (primeiro é o do canal)
    if (titleMatch && titleMatch[1]) {
      latestVideo.title = titleMatch[1].replace(/<\/?title>/g, '');
    }
  }
} catch {}

const recentPosts = (await getCollection('blog'))
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf())
  .slice(0, 3);

const servicos = [
  {
    titulo: 'Modelagem Feminina',
    descricao: 'Moldes únicos desenvolvidos a partir das suas medidas, garantindo caimento perfeito e exclusividade em cada peça.',
    numero: '01',
  },
  {
    titulo: 'Alfaiataria Feminina',
    descricao: 'Ternos, blazers e peças estruturadas com acabamento impecável. Precisão técnica aliada a um olhar contemporâneo.',
    numero: '02',
  },
  {
    titulo: 'Alta Costura',
    descricao: 'Criações sob medida para ocasiões especiais. Do rascunho ao vestido final, um processo artesanal e personalizado.',
    numero: '03',
  },
  {
    titulo: 'Consultoria de Modelagem',
    descricao: 'Orientação técnica para ateliês, estilistas e marcas que buscam excelência na construção de coleções.',
    numero: '04',
  },
];

const portfolio = [
  {
    titulo: 'Coleção Primavera',
    categoria: 'Alta Costura',
    img: `${UNSPLASH}/photo-1490481651871-ab68de25d43d?w=700&h=875&fit=crop&q=80`,
    fotos: [
      `${UNSPLASH}/photo-1490481651871-ab68de25d43d?w=1200&h=1500&fit=crop&q=85`,
      `${UNSPLASH}/photo-1509631179647-0177331693ae?w=1200&h=1500&fit=crop&q=85`,
      `${UNSPLASH}/photo-1496747611176-843222e1e57c?w=1200&h=1500&fit=crop&q=85`,
    ],
  },
  {
    titulo: 'Alfaiataria Contemporânea',
    categoria: 'Alfaiataria',
    img: `${UNSPLASH}/photo-1445205170230-053b83016050?w=700&h=875&fit=crop&q=80`,
    fotos: [
      `${UNSPLASH}/photo-1445205170230-053b83016050?w=1200&h=1500&fit=crop&q=85`,
      `${UNSPLASH}/photo-1594938298603-c8148c4b2bca?w=1200&h=1500&fit=crop&q=85`,
      `${UNSPLASH}/photo-1567401893414-76b7b1e5a7a5?w=1200&h=1500&fit=crop&q=85`,
    ],
  },
  {
    titulo: 'Noiva Contemporânea',
    categoria: 'Alta Costura',
    img: `${UNSPLASH}/photo-1515886657613-9f3515b0c78f?w=700&h=875&fit=crop&q=80`,
    fotos: [
      `${UNSPLASH}/photo-1515886657613-9f3515b0c78f?w=1200&h=1500&fit=crop&q=85`,
      `${UNSPLASH}/photo-1519741347686-c1e0aadf4611?w=1200&h=1500&fit=crop&q=85`,
      `${UNSPLASH}/photo-1511285560929-80b456fea0bc?w=1200&h=1500&fit=crop&q=85`,
    ],
  },
  {
    titulo: 'Prêt-à-Porter',
    categoria: 'Modelagem',
    img: `${UNSPLASH}/photo-1539109136881-3be0616acf4b?w=700&h=875&fit=crop&q=80`,
    fotos: [
      `${UNSPLASH}/photo-1539109136881-3be0616acf4b?w=1200&h=1500&fit=crop&q=85`,
      `${UNSPLASH}/photo-1485230895905-ec40ba36b9bc?w=1200&h=1500&fit=crop&q=85`,
      `${UNSPLASH}/photo-1483985988355-763728e1935b?w=1200&h=1500&fit=crop&q=85`,
    ],
  },
  {
    titulo: 'Coleção Outono',
    categoria: 'Modelagem',
    img: `${UNSPLASH}/photo-1558769132-cb1aea458c5e?w=700&h=875&fit=crop&q=80`,
    fotos: [
      `${UNSPLASH}/photo-1558769132-cb1aea458c5e?w=1200&h=1500&fit=crop&q=85`,
      `${UNSPLASH}/photo-1536766820879-059fec98ec0a?w=1200&h=1500&fit=crop&q=85`,
      `${UNSPLASH}/photo-1469334031218-e382a71b716b?w=1200&h=1500&fit=crop&q=85`,
    ],
  },
  {
    titulo: 'Atelier Exclusivo',
    categoria: 'Alta Costura',
    img: `${UNSPLASH}/photo-1469334031218-e382a71b716b?w=700&h=875&fit=crop&q=80`,
    fotos: [
      `${UNSPLASH}/photo-1469334031218-e382a71b716b?w=1200&h=1500&fit=crop&q=85`,
      `${UNSPLASH}/photo-1490481651871-ab68de25d43d?w=1200&h=1500&fit=crop&q=85`,
      `${UNSPLASH}/photo-1515886657613-9f3515b0c78f?w=1200&h=1500&fit=crop&q=85`,
    ],
  },
];
---

<Layout>
  <Nav />

  <!-- HERO -->
  <section class="relative min-h-screen flex items-end pt-24 pb-24 px-6 lg:px-12 lg:pt-0 overflow-hidden" style="background-color: #FAF8F4;">
    <div class="absolute inset-0 overflow-hidden pointer-events-none">
      <div class="absolute top-0 right-0 w-1/2 h-full" style="background-color: #F0EDE6; clip-path: polygon(15% 0, 100% 0, 100% 100%, 0% 100%);"></div>
      <div class="absolute top-1/4 right-[10%] w-px h-64 animate-fade-in delay-900" style="background-color: rgba(184,137,106,0.2);"></div>
      <div class="absolute bottom-1/3 right-[25%] w-32 h-32 rounded-full animate-fade-in delay-700" style="border: 1px solid rgba(184,137,106,0.15);"></div>
    </div>

    <div class="relative max-w-7xl mx-auto w-full grid grid-cols-1 lg:grid-cols-2 gap-16 items-end">
      <div>
        <p class="text-xs tracking-[0.35em] uppercase mb-8 animate-fade-up delay-100 font-medium" style="color: #B8896A;">
          Modelista de Moda
        </p>
        <h1 class="font-display leading-[0.92] font-light animate-fade-up delay-200" style="font-size: clamp(4rem,10vw,8.5rem); color: #1C1917;">
          Vany<br/>
          <em class="italic" style="color: #B8896A;">Modelista</em>
        </h1>

        <div class="h-px mt-10 mb-10 animate-line delay-500 origin-left" style="background-color: rgba(184,137,106,0.4); max-width: 120px;"></div>

        <p class="text-base leading-relaxed max-w-sm font-light animate-fade-up delay-500" style="color: #44403C;">
          Vinte anos transformando visões em peças únicas. Cada molde é uma história — contada com precisão, sensibilidade e olhar apurado.
        </p>

        <div class="flex gap-4 mt-10 animate-fade-up delay-700">
          <a href="#contato" class="inline-flex items-center gap-3 px-8 py-4 text-xs tracking-[0.2em] uppercase font-medium transition-colors duration-500" style="background-color: #1C1917; color: #FAF8F4;">
            Fale Comigo
          </a>
          <a href="#portfolio" class="inline-flex items-center gap-3 px-8 py-4 text-xs tracking-[0.2em] uppercase font-medium transition-colors duration-500" style="border: 1px solid rgba(28,25,23,0.3); color: #1C1917;">
            Ver Portfólio
          </a>
        </div>
      </div>

      <!-- Hero image -->
      <div class="relative animate-fade-in delay-300 lg:max-w-md lg:ml-auto">
        <div class="aspect-[3/4] relative overflow-hidden">
          <img
            src="/hero-mannequins.jpg"
            alt="Manequins de costura"
            class="w-full h-full object-cover"
          />
          <div class="absolute inset-0" style="background: linear-gradient(to top, rgba(28,25,23,0.3) 0%, transparent 60%);"></div>
        </div>
        <div class="absolute -bottom-4 -left-4 w-24 h-24 -z-10" style="background-color: #EDD9CB;"></div>
        <div class="absolute -top-4 -right-4 w-full h-full -z-10" style="border: 1px solid rgba(184,137,106,0.2);"></div>
      </div>
    </div>

    <div class="hidden lg:flex absolute bottom-10 left-1/2 -translate-x-1/2 flex-col items-center gap-2 animate-fade-in delay-900">
      <p class="text-[10px] tracking-[0.3em] uppercase" style="color: #8C7B74;">Rolar</p>
      <div class="w-px h-12" style="background-color: rgba(184,137,106,0.4);"></div>
    </div>
  </section>

  <!-- SOBRE -->
  <section id="sobre" class="py-32 px-6 lg:px-12 overflow-hidden" style="background-color: #1C1917; color: #FAF8F4;">
    <div class="max-w-7xl mx-auto grid grid-cols-1 lg:grid-cols-2 gap-20 items-center">
      <div class="relative">
        <div class="aspect-square relative overflow-hidden">
          <img
            src={`${UNSPLASH}/photo-1512436991641-6745cdb1723f?w=800&h=800&fit=crop&q=85`}
            alt="Trabalho de modelagem"
            class="w-full h-full object-cover"
          />
          <div class="absolute inset-0" style="background: linear-gradient(to top, rgba(28,25,23,0.6) 0%, transparent 50%);"></div>
          <div class="absolute bottom-0 left-0 right-0 p-8">
            <div class="h-px mb-4 w-16" style="background-color: rgba(184,137,106,0.6);"></div>
            <p class="text-xs tracking-[0.25em] uppercase" style="color: #D4A88A;">Vany Modelista</p>
          </div>
        </div>
        <div class="absolute -top-6 -right-6 w-32 h-32" style="border: 1px solid rgba(184,137,106,0.2);"></div>

      </div>

      <div>
        <p class="text-xs tracking-[0.35em] uppercase mb-6 font-medium" style="color: #D4A88A;">Sobre Mim</p>
        <h2 class="font-display text-5xl lg:text-6xl font-light leading-tight mb-8">
          Onde técnica<br/>
          encontra <em class="italic" style="color: #D4A88A;">arte</em>
        </h2>
        <div class="h-px w-16 mb-8" style="background-color: rgba(184,137,106,0.3);"></div>
        <div class="space-y-5 font-light leading-relaxed" style="color: #8C7B74;">
          <p>
            Com mais de vinte anos dedicados à costura e à modelagem de roupas femininas, desenvolvi um olhar que vai além do molde — enxergo a pessoa dentro da peça, seu movimento e sua história. Costuro desde a infância e iniciei meus estudos em modelagem em 2011, quando ainda era menina. Hoje, aos 31 anos, sigo aprofundando meu conhecimento por meio de cursos de extensão universitária voltados à modelagem de moda feminina.
          </p>
          <p>
            Tenho uma conexão especial com a alfaiataria feminina, área que mais me encanta e na qual busco constante aperfeiçoamento. Ao longo da minha trajetória, venho construindo uma prática sensível e técnica, unindo precisão, caimento e identidade em cada peça.
          </p>
          <p>
            Cada projeto começa com escuta. O molde perfeito nasce de um diálogo — entre corpo, desejo e matéria-prima.
          </p>
        </div>
        <a href="#contato" class="inline-flex items-center gap-3 mt-10 text-xs tracking-[0.2em] uppercase pb-1 transition-colors duration-300" style="color: #D4A88A; border-bottom: 1px solid rgba(184,137,106,0.3);">
          Iniciar um projeto →
        </a>
      </div>
    </div>
  </section>

  <!-- SERVIÇOS -->
  <section id="servicos" class="py-32 px-6 lg:px-12" style="background-color: #FAF8F4;">
    <div class="max-w-7xl mx-auto">
      <div class="flex flex-col md:flex-row md:items-end justify-between mb-20 gap-6">
        <div>
          <p class="text-xs tracking-[0.35em] uppercase mb-4 font-medium" style="color: #B8896A;">O que faço</p>
          <h2 class="font-display text-5xl lg:text-7xl font-light leading-tight" style="color: #1C1917;">Serviços</h2>
        </div>
        <p class="text-sm max-w-xs font-light leading-relaxed md:text-right" style="color: #8C7B74;">
          Cada serviço é uma entrega completa — da concepção ao acabamento final.
        </p>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-2 gap-px" style="background-color: #F0EDE6;">
        {servicos.map((s) => (
          <div class="p-10 lg:p-14 group cursor-default transition-all duration-500 hover:bg-charcoal" style="background-color: #FAF8F4;">
            <div class="flex items-start justify-between mb-8">
              <span class="font-display text-6xl font-light leading-none" style="color: rgba(184,137,106,0.2);">
                {s.numero}
              </span>
              <div class="w-8 h-px mt-5 transition-all duration-500 group-hover:w-16" style="background-color: rgba(184,137,106,0.3);"></div>
            </div>
            <h3 class="font-display text-2xl font-light mb-4 leading-snug transition-colors duration-500 group-hover:text-cream" style="color: #1C1917;">
              {s.titulo}
            </h3>
            <p class="text-sm font-light leading-relaxed transition-colors duration-500 group-hover:text-[rgba(140,123,116,0.8)]" style="color: #8C7B74;">
              {s.descricao}
            </p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- PORTFÓLIO -->
  <section id="portfolio" class="py-32 px-6 lg:px-12" style="background-color: #F0EDE6;">
    <div class="max-w-7xl mx-auto">
      <div class="mb-20">
        <p class="text-xs tracking-[0.35em] uppercase mb-4 font-medium" style="color: #B8896A;">Trabalhos</p>
        <h2 class="font-display text-5xl lg:text-7xl font-light leading-tight" style="color: #1C1917;">Portfólio</h2>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
        {portfolio.map((item) => (
          <div
            class="group relative overflow-hidden cursor-pointer portfolio-card"
            data-titulo={item.titulo}
            data-categoria={item.categoria}
            data-fotos={JSON.stringify(item.fotos)}
          >
            <div class="aspect-[4/5] relative overflow-hidden">
              <img
                src={item.img}
                alt={item.titulo}
                class="w-full h-full object-cover transition-transform duration-700 group-hover:scale-105"
                loading="lazy"
              />
              <div class="absolute inset-0 transition-all duration-500" style="background: linear-gradient(to top, rgba(28,25,23,0.7) 0%, rgba(28,25,23,0.1) 50%, transparent 100%);"></div>
              <div class="absolute inset-0 flex items-center justify-center opacity-0 group-hover:opacity-100 transition-opacity duration-500" style="background-color: rgba(28,25,23,0.3);">
                <p class="text-xs tracking-[0.3em] uppercase" style="color: #FAF8F4;">Ver peça</p>
              </div>
              <div class="absolute bottom-0 left-0 right-0 p-6">
                <p class="text-[10px] tracking-[0.25em] uppercase mb-1" style="color: rgba(212,168,138,0.8);">{item.categoria}</p>
                <p class="font-display text-xl font-light" style="color: #FAF8F4;">{item.titulo}</p>
              </div>
            </div>
          </div>
        ))}
      </div>

      <!-- Instagram CTA destacado -->
      <div class="mt-20 relative overflow-hidden" style="background-color: #1C1917;">
        <div class="absolute inset-0 pointer-events-none overflow-hidden">
          <div class="absolute -top-16 -right-16 w-64 h-64 rounded-full" style="border: 1px solid rgba(184,137,106,0.1);"></div>
          <div class="absolute -bottom-8 -left-8 w-32 h-32 rounded-full" style="border: 1px solid rgba(184,137,106,0.08);"></div>
        </div>
        <div class="relative px-10 py-14 flex flex-col md:flex-row items-center justify-between gap-8">
          <div class="flex items-center gap-6">
            <div class="w-14 h-14 rounded-full flex items-center justify-center shrink-0" style="background: linear-gradient(135deg, #f09433, #e6683c, #dc2743, #cc2366, #bc1888);">
              <svg class="w-7 h-7 text-white" fill="currentColor" viewBox="0 0 24 24">
                <path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zm0-2.163c-3.259 0-3.667.014-4.947.072-4.358.2-6.78 2.618-6.98 6.98-.059 1.281-.073 1.689-.073 4.948 0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98 1.281.058 1.689.072 4.948.072 3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98-1.281-.059-1.69-.073-4.949-.073zm0 5.838c-3.403 0-6.162 2.759-6.162 6.162s2.759 6.163 6.162 6.163 6.162-2.759 6.162-6.163c0-3.403-2.759-6.162-6.162-6.162zm0 10.162c-2.209 0-4-1.79-4-4 0-2.209 1.791-4 4-4s4 1.791 4 4c0 2.21-1.791 4-4 4zm6.406-11.845c-.796 0-1.441.645-1.441 1.44s.645 1.44 1.441 1.44c.795 0 1.439-.645 1.439-1.44s-.644-1.44-1.439-1.44z"/>
              </svg>
            </div>
            <div>
              <p class="text-xs tracking-[0.25em] uppercase mb-1" style="color: #D4A88A;">Acompanhe o processo</p>
              <p class="font-display text-2xl font-light" style="color: #FAF8F4;">
                Bastidores, moldes e peças no Instagram
              </p>
            </div>
          </div>
          <a
            href="https://instagram.com/vanymodelista"
            target="_blank"
            rel="noopener noreferrer"
            class="shrink-0 inline-flex items-center gap-3 px-8 py-4 text-xs tracking-[0.2em] uppercase font-medium transition-all duration-300 hover:gap-5"
            style="background: linear-gradient(135deg, #f09433, #e6683c, #dc2743, #cc2366, #bc1888); color: #FAF8F4;"
          >
            @vanymodelista
            <span>→</span>
          </a>
        </div>
      </div>
    </div>
  </section>

  <!-- YOUTUBE CTA -->
  <section class="py-24 px-6 lg:px-12 relative overflow-hidden" style="background-color: #FAF8F4;">
    <div class="max-w-7xl mx-auto">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 items-center">
        <div>
          <p class="text-xs tracking-[0.35em] uppercase mb-4 font-medium" style="color: #B8896A;">Canal no YouTube</p>
          <h2 class="font-display text-4xl lg:text-5xl font-light leading-tight mb-6" style="color: #1C1917;">
            Aprenda modelagem<br/>
            <em class="italic" style="color: #B8896A;">de graça</em>
          </h2>
          <p class="text-sm font-light leading-relaxed max-w-md mb-8" style="color: #8C7B74;">
            Tutoriais, bastidores do atelier e técnicas profissionais — direto no YouTube. Novos vídeos toda semana para quem quer aprender a costurar do jeito certo.
          </p>
          <a
            href="https://youtube.com/@vanymodelista"
            target="_blank"
            rel="noopener noreferrer"
            class="inline-flex items-center gap-3 px-8 py-4 text-xs tracking-[0.2em] uppercase font-medium transition-colors duration-300 hover:opacity-90"
            style="background-color: #FF0000; color: #FAF8F4;"
          >
            <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24">
              <path d="M23.498 6.186a3.016 3.016 0 0 0-2.122-2.136C19.505 3.545 12 3.545 12 3.545s-7.505 0-9.377.505A3.017 3.017 0 0 0 .502 6.186C0 8.07 0 12 0 12s0 3.93.502 5.814a3.016 3.016 0 0 0 2.122 2.136c1.871.505 9.376.505 9.376.505s7.505 0 9.377-.505a3.015 3.015 0 0 0 2.122-2.136C24 15.93 24 12 24 12s0-3.93-.502-5.814zM9.545 15.568V8.432L15.818 12l-6.273 3.568z"/>
            </svg>
            Inscreva-se no Canal
          </a>
        </div>

        <!-- Último vídeo do canal -->
        <div class="relative">
          <div id="yt-player" class="aspect-video relative overflow-hidden cursor-pointer" style="background-color: #1C1917;" data-video-id={latestVideo.id}>
            {latestVideo.thumbnail ? (
              <img
                src={latestVideo.thumbnail}
                alt={latestVideo.title}
                class="w-full h-full object-cover opacity-80"
              />
            ) : (
              <div class="w-full h-full" style="background-color: #1C1917;"></div>
            )}
            <!-- Play button -->
            <div class="absolute inset-0 flex items-center justify-center">
              <div class="w-16 h-16 rounded-full flex items-center justify-center transition-transform duration-300 hover:scale-110" style="background-color: rgba(255,0,0,0.9);">
                <svg class="w-7 h-7 translate-x-0.5" fill="white" viewBox="0 0 24 24">
                  <path d="M8 5v14l11-7z"/>
                </svg>
              </div>
            </div>
            <div class="absolute bottom-0 left-0 right-0 px-5 py-4" style="background: linear-gradient(to top, rgba(28,25,23,0.9), transparent);">
              <p class="text-xs tracking-[0.2em] uppercase mb-1" style="color: #D4A88A;">Último vídeo</p>
              <p class="font-display text-lg font-light" style="color: #FAF8F4;">{latestVideo.title}</p>
            </div>
          </div>
        </div>

        <script>
          const player = document.getElementById('yt-player');
          if (player) {
            player.addEventListener('click', () => {
              const videoId = player.dataset.videoId;
              if (!videoId) return;
              const iframe = document.createElement('iframe');
              iframe.src = `https://www.youtube.com/embed/${videoId}?autoplay=1`;
              iframe.allow = 'autoplay; encrypted-media';
              iframe.allowFullscreen = true;
              iframe.className = 'absolute inset-0 w-full h-full';
              player.innerHTML = '';
              player.appendChild(iframe);
            });
          }
