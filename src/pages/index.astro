        <script>
          const form = document.getElementById('contact-form') as HTMLFormElement;
          const result = document.getElementById('form-result')!;
          const btn = document.getElementById('submit-btn') as HTMLButtonElement;
          const celularInput = document.getElementById('celular-input') as HTMLInputElement;

          celularInput.addEventListener('input', () => {
            let v = celularInput.value.replace(/\D/g, '').slice(0, 11);
            if (v.length > 6) v = `(${v.slice(0,2)}) ${v.slice(2,7)}-${v.slice(7)}`;
            else if (v.length > 2) v = `(${v.slice(0,2)}) ${v.slice(2)}`;
            else if (v.length > 0) v = `(${v}`;
            celularInput.value = v;
          });

          const btnText = document.getElementById('btn-text')!;
          const btnLoading = document.getElementById('btn-loading')!;

          function setLoading(on: boolean) {
            btn.disabled = on;
            btnText.classList.toggle('hidden', on);
            btnLoading.classList.toggle('hidden', !on);
            btnLoading.classList.toggle('flex', on);
          }

          form.addEventListener('submit', async (e) => {
            e.preventDefault();
            setLoading(true);

            const data = Object.fromEntries(new FormData(form));

            try {
              const res = await fetch('https://api.web3forms.com/submit', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json', 'Accept': 'application/json' },
                body: JSON.stringify(data),
              });
              const json = await res.json();

              if (res.ok && json.success) {
                result.textContent = 'Mensagem enviada com sucesso. Entrarei em contato em breve.';
                result.style.cssText = 'color:#44403C; background:rgba(184,137,106,0.1); border:1px solid rgba(184,137,106,0.3);';
                result.classList.remove('hidden');
                form.reset();
              } else {
                throw new Error(json.message ?? 'Erro ao enviar');
              }
            } catch {
              result.textContent = 'Não foi possível enviar. Tente novamente ou entre em contato pelo Instagram.';
              result.style.cssText = 'color:#7f1d1d; background:rgba(220,38,38,0.05); border:1px solid rgba(220,38,38,0.2);';
              result.classList.remove('hidden');
            } finally {
              setLoading(false);
              btn.textContent = 'Enviar Mensagem';
            }
          });
        </script>
      </div>
